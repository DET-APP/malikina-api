    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.2.2",
    "pdfjs-dist": "^4.0.0",
    "pg": "^8.11.3",
